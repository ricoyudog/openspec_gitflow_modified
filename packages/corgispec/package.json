{
  "name": "corgispec",
  "version": "0.1.0",
  "description": "Unified CLI for OpenSpec workflow — skill management, validation, and AI instruction generation",
  "type": "module",
  "bin": {
    "corgispec": "./dist/corgispec.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && node scripts/bundle-assets.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "assets"
  ],
  "keywords": [
    "openspec",
    "cli",
    "workflow",
    "ai",
    "skills",
    "spec-driven-development"
  ],
  "license": "MIT",
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.2",
    "ajv": "^8.17.1",
    "commander": "^13.1.0",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
